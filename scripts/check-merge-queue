#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path


LAB_ROOT = Path(__file__).resolve().parents[1]
if str(LAB_ROOT) not in sys.path:
    sys.path.insert(0, str(LAB_ROOT))

from lab_agents.worktree_merge_queue import merge_queue_report


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Validate the lab worktree merge queue registry state.")
    parser.add_argument("--root", type=Path, default=LAB_ROOT, help="Lab root to validate.")
    parser.add_argument("--json", action="store_true", help="Print structured JSON.")
    return parser.parse_args()


def main() -> int:
    args = parse_args()
    report = merge_queue_report(args.root.expanduser().resolve())
    if args.json:
        print(json.dumps(report, indent=2, sort_keys=True))
    else:
        summary = report["summary"]
        print(f"Merge queue: {report['status']}")
        print(
            "Streams: {stream_count}, active: {active_count}, queued: {queued_count}, "
            "merged: {merged_count}, refused: {refused_count}".format(**summary)
        )
        for issue in report["issues"]:
            print(f"{issue['code']}: {issue['message']}", file=sys.stderr)
    return 1 if report["status"] == "fail" else 0


if __name__ == "__main__":
    raise SystemExit(main())
