#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LAB_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

fail() {
  printf 'FAIL: %s\n' "$*" >&2
  exit 1
}

check_file() {
  local file="$1"
  test -f "$file" || fail "missing file: $file"
}

check_pattern() {
  local file="$1"
  local pattern="$2"
  local label="$3"
  rg -q "$pattern" "$file" || fail "$label missing in $file"
}

check_file "$LAB_ROOT/AGENTS.md"
check_file "$LAB_ROOT/docs/agent-lab-mission.md"
check_file "$LAB_ROOT/docs/project-rule-template.md"
check_file "$LAB_ROOT/docs/scenario-workspace-contract.md"
check_file "$LAB_ROOT/docs/runtime-compatibility.md"
check_file "$LAB_ROOT/docs/workspace-safety-contract.md"
check_file "$LAB_ROOT/docs/reasoning-speed-playbook.md"
check_file "$LAB_ROOT/docs/waterflow-speed-contract.md"
check_file "$LAB_ROOT/docs/sandbox-boundaries.md"
check_file "$LAB_ROOT/registry/CAPABILITY_LAYERS.md"
check_file "$LAB_ROOT/registry/current-progress.md"
check_file "$LAB_ROOT/registry/VALIDATION.md"
test -x "$LAB_ROOT/scripts/check-sandbox" || fail "sandbox check script missing or not executable"
test -x "$LAB_ROOT/scripts/check-runtime-compatibility" || fail "runtime compatibility check script missing or not executable"
test -x "$LAB_ROOT/scripts/check-workspace-safety" || fail "workspace safety check script missing or not executable"
test -x "$LAB_ROOT/scripts/check-async-execution" || fail "async execution check script missing or not executable"
test -x "$LAB_ROOT/scripts/check-sandbox-skills" || fail "sandbox skill check script missing or not executable"
test -x "$LAB_ROOT/scripts/check-speed-contract" || fail "speed contract check script missing or not executable"
test -x "$LAB_ROOT/scripts/benchmark-ide-loop" || fail "IDE benchmark script missing or not executable"
test -x "$LAB_ROOT/scripts/lab-dashboard" || fail "lab dashboard script missing or not executable"
test -x "$LAB_ROOT/scripts/development-experience-audit" || fail "development experience audit script missing or not executable"
test -x "$LAB_ROOT/scripts/large-agent-readiness-audit" || fail "large agent readiness audit script missing or not executable"

check_pattern "$LAB_ROOT/AGENTS.md" '^## Mission And Quality Bar$' "mission and quality bar section"
check_pattern "$LAB_ROOT/docs/agent-lab-mission.md" '^## Mission$' "mission section"
check_pattern "$LAB_ROOT/docs/agent-lab-mission.md" '^## Quality Bar$' "quality bar section"
check_pattern "$LAB_ROOT/docs/agent-lab-mission.md" '^## Expansion Rule$' "expansion rule section"
check_pattern "$LAB_ROOT/AGENTS.md" '^## Project-Level Rule Expansion$' "project-level expansion section"
check_pattern "$LAB_ROOT/docs/project-rule-template.md" '^## Project Identity$' "template project identity section"
check_pattern "$LAB_ROOT/docs/project-rule-template.md" '^## Scenario Boundary$' "template scenario boundary section"
check_pattern "$LAB_ROOT/docs/project-rule-template.md" '^## Codex Claude Amplification$' "template Codex Claude amplification section"
check_pattern "$LAB_ROOT/docs/project-rule-template.md" '^## Runtime Routing$' "template runtime routing section"
check_pattern "$LAB_ROOT/docs/project-rule-template.md" '^## Verification$' "template verification section"
check_pattern "$LAB_ROOT/docs/project-rule-template.md" '^## Handoff$' "template handoff section"
check_pattern "$LAB_ROOT/docs/scenario-workspace-contract.md" '^## Scenario Boundary$' "scenario workspace boundary section"
check_pattern "$LAB_ROOT/docs/scenario-workspace-contract.md" '^## Codex Claude Amplification$' "scenario workspace amplification section"
check_pattern "$LAB_ROOT/docs/scenario-workspace-contract.md" '^## Promotion Rule$' "scenario workspace promotion section"
check_pattern "$LAB_ROOT/docs/runtime-compatibility.md" '^## Required Checks$' "runtime compatibility required checks section"
check_pattern "$LAB_ROOT/docs/runtime-compatibility.md" '^## Warning Checks$' "runtime compatibility warning checks section"
check_pattern "$LAB_ROOT/docs/runtime-compatibility.md" '^## Runtime State Rules$' "runtime compatibility runtime-state section"
check_pattern "$LAB_ROOT/docs/runtime-compatibility.md" '^## Health Gate$' "runtime compatibility health gate section"
check_pattern "$LAB_ROOT/docs/workspace-safety-contract.md" '^## Hard Failures$' "workspace safety hard failures section"
check_pattern "$LAB_ROOT/docs/workspace-safety-contract.md" '^## Warnings$' "workspace safety warnings section"
check_pattern "$LAB_ROOT/docs/workspace-safety-contract.md" '^## New Workspace Template$' "workspace safety template section"
check_pattern "$LAB_ROOT/docs/workspace-safety-contract.md" '^## Health Gate$' "workspace safety health gate section"
check_pattern "$LAB_ROOT/docs/reasoning-speed-playbook.md" '^## Practical Speed Levers$' "reasoning speed levers section"
check_pattern "$LAB_ROOT/docs/reasoning-speed-playbook.md" '^## Async Safety$' "reasoning async safety section"
check_pattern "$LAB_ROOT/docs/waterflow-speed-contract.md" '^## Fast Path$' "waterflow speed fast path section"
check_pattern "$LAB_ROOT/docs/waterflow-speed-contract.md" '^## Blocking Rules$' "waterflow speed blocking rules section"
check_pattern "$LAB_ROOT/README.md" 'scripts/benchmark-ide-loop' "README IDE benchmark command"
check_pattern "$LAB_ROOT/README.md" 'scripts/lab-dashboard' "README lab dashboard command"
check_pattern "$LAB_ROOT/README.md" 'scripts/check-runtime-compatibility' "README runtime compatibility command"
check_pattern "$LAB_ROOT/README.md" 'scripts/check-workspace-safety' "README workspace safety command"
check_pattern "$LAB_ROOT/README.md" 'scripts/development-experience-audit' "README development experience audit command"
check_pattern "$LAB_ROOT/README.md" 'scripts/large-agent-readiness-audit' "README large agent readiness audit command"
check_pattern "$LAB_ROOT/docs/sandbox-boundaries.md" '^## Writable Boundary$' "sandbox writable boundary section"
check_pattern "$LAB_ROOT/docs/sandbox-boundaries.md" '^## Health Gate$' "sandbox health gate section"
check_pattern "$LAB_ROOT/docs/sandbox-boundaries.md" '^## Sandbox Skills$' "sandbox skills section"
check_pattern "$LAB_ROOT/AGENTS.md" 'scripts/check-runtime-compatibility' "AGENTS runtime compatibility gate reference"
check_pattern "$LAB_ROOT/AGENTS.md" 'scripts/check-workspace-safety' "AGENTS workspace safety gate reference"
check_pattern "$LAB_ROOT/registry/CAPABILITY_LAYERS.md" '^## Mission Anchor$' "capability mission anchor"
check_pattern "$LAB_ROOT/registry/CAPABILITY_LAYERS.md" '^## Layer 1: Project-Level Rules$' "capability layer 1 section"
check_pattern "$LAB_ROOT/registry/CAPABILITY_LAYERS.md" 'scripts/check-runtime-compatibility' "capability layer runtime compatibility reference"
check_pattern "$LAB_ROOT/registry/CAPABILITY_LAYERS.md" 'scripts/check-workspace-safety' "capability layer workspace safety reference"
check_pattern "$LAB_ROOT/scripts/new-workspace" 'AGENTS.md' "new workspace local AGENTS creation"
check_pattern "$LAB_ROOT/scripts/new-workspace" '.gitignore' "new workspace local gitignore creation"
check_pattern "$LAB_ROOT/scripts/new-workspace" '## Scenario Boundary' "new workspace scenario boundary section"
check_pattern "$LAB_ROOT/scripts/new-workspace" '## Codex Claude Amplification' "new workspace amplification section"
check_pattern "$LAB_ROOT/scripts/new-workspace" 'Scenario type: TBD' "new workspace scenario type field"

"$LAB_ROOT/scripts/check-workspace-safety" >/dev/null

printf 'OK: project rule surfaces are valid\n'
