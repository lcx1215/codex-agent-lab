#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LAB_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
cd "$LAB_ROOT"

fail() {
  printf 'FAIL: %s\n' "$*" >&2
  exit 1
}

test -d .git || fail "check-secrets must run from a git checkout"

forbidden_paths='(^|/)(auth\.json|\.env($|\.)|.*\.(pem|key|p12|pfx)$)'
if git ls-files --cached --others --exclude-standard | rg -n "$forbidden_paths" >/tmp/codex-agent-lab-secret-paths.$$; then
  cat /tmp/codex-agent-lab-secret-paths.$$ >&2
  rm -f /tmp/codex-agent-lab-secret-paths.$$
  fail "committable secret-like file path detected"
fi
rm -f /tmp/codex-agent-lab-secret-paths.$$

secret_patterns=(
  'gh[opsu]_[A-Za-z0-9_]{30,}'
  'github_pat_[A-Za-z0-9_]{20,}'
  'sk-[A-Za-z0-9_-]{20,}'
  'AKIA[0-9A-Z]{16}'
  '-----BEGIN (RSA |OPENSSH |EC |DSA )?PRIVATE KEY-----'
)

for pattern in "${secret_patterns[@]}"; do
  if rg -I -n --no-heading --hidden \
    -g '!.git/**' \
    -g '!outputs/**' \
    -g '!workspaces/**' \
    -g '!.codex-home/**' \
    -g '!.omx/**' \
    -e "$pattern" . |
    awk -F: '{ print $1 ":" $2 }' |
    sort -u >/tmp/codex-agent-lab-secret-grep.$$; then
    cat /tmp/codex-agent-lab-secret-grep.$$ >&2
    rm -f /tmp/codex-agent-lab-secret-grep.$$
    fail "secret-like token detected; content redacted"
  fi
done
rm -f /tmp/codex-agent-lab-secret-grep.$$

if rg -n '/Users/' README.md >/tmp/codex-agent-lab-readme-local-paths.$$; then
  cat /tmp/codex-agent-lab-readme-local-paths.$$ >&2
  rm -f /tmp/codex-agent-lab-readme-local-paths.$$
  fail "README contains machine-local /Users paths"
fi
rm -f /tmp/codex-agent-lab-readme-local-paths.$$

printf 'OK: no committable secrets or README-local user paths detected\n'
