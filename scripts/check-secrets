#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LAB_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
cd "$LAB_ROOT"

fail() {
  printf 'FAIL: %s\n' "$*" >&2
  exit 1
}

test -d .git || fail "check-secrets must run from a git checkout"

# This is a security gate. It MUST fail closed: if the scanner (ripgrep) is not
# available, refuse to report "OK" rather than silently scanning nothing.
# ripgrep is not always on PATH (e.g. it ships inside Codex.app on macOS), so
# probe a few known locations before giving up.
if ! command -v rg >/dev/null 2>&1; then
  for candidate in \
    /Applications/Codex.app/Contents/Resources/rg \
    /opt/homebrew/bin/rg \
    /usr/local/bin/rg; do
    if [ -x "$candidate" ]; then
      PATH="$(dirname "$candidate"):$PATH"
      export PATH
      break
    fi
  done
fi
command -v rg >/dev/null 2>&1 || fail "ripgrep (rg) not found; refusing to run secret scan that would otherwise pass without scanning"

TMP_ROOT="$LAB_ROOT/.tmp/check-secrets.$$"
mkdir -p "$TMP_ROOT"
trap 'rm -rf "$TMP_ROOT"' EXIT

forbidden_paths='(^|/)(auth\.json|\.env($|\.)|.*\.(pem|key|p12|pfx)$)'
git ls-files --cached --others --exclude-standard >"$TMP_ROOT/committable-paths"
set +e
rg -n --no-heading --color never "$forbidden_paths" "$TMP_ROOT/committable-paths" >"$TMP_ROOT/secret-paths" 2>"$TMP_ROOT/secret-paths.err"
rg_status=$?
set -e
if [ "$rg_status" -eq 0 ]; then
  cat "$TMP_ROOT/secret-paths" >&2
  fail "committable secret-like file path detected"
fi
if [ "$rg_status" -ne 1 ]; then
  cat "$TMP_ROOT/secret-paths.err" >&2
  fail "ripgrep path scan failed"
fi

secret_patterns=(
  'gh[opsu]_[A-Za-z0-9_]{30,}'
  'github_pat_[A-Za-z0-9_]{20,}'
  '(^|[^A-Za-z0-9_])sk-[A-Za-z0-9_-]{20,}'
  'AKIA[0-9A-Z]{16}'
  '-----BEGIN (RSA |OPENSSH |EC |DSA )?PRIVATE KEY-----'
)

for pattern in "${secret_patterns[@]}"; do
  set +e
  rg -I -n --with-filename --no-heading --hidden \
    -g '!.git/**' \
    -g '!outputs/**' \
    -g '!workspaces/**' \
    -g '!.tmp/**' \
    -g '!.codex-home/**' \
    -g '!.omx/**' \
    -e "$pattern" . >"$TMP_ROOT/secret-grep-raw" 2>"$TMP_ROOT/secret-grep.err"
  rg_status=$?
  set -e
  if [ "$rg_status" -eq 0 ]; then
    awk -F: '{ print $1 ":" $2 }' "$TMP_ROOT/secret-grep-raw" |
      sort -u >"$TMP_ROOT/secret-grep"
    cat "$TMP_ROOT/secret-grep" >&2
    fail "secret-like token detected; content redacted"
  fi
  if [ "$rg_status" -ne 1 ]; then
    cat "$TMP_ROOT/secret-grep.err" >&2
    fail "ripgrep content scan failed"
  fi
done

set +e
rg -n '/Users/' README.md >"$TMP_ROOT/readme-local-paths" 2>"$TMP_ROOT/readme-local-paths.err"
rg_status=$?
set -e
if [ "$rg_status" -eq 0 ]; then
  cat "$TMP_ROOT/readme-local-paths" >&2
  fail "README contains machine-local /Users paths"
fi
if [ "$rg_status" -ne 1 ]; then
  cat "$TMP_ROOT/readme-local-paths.err" >&2
  fail "ripgrep README local-path scan failed"
fi

printf 'OK: no committable secrets or README-local user paths detected\n'
