#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path


LAB_ROOT = Path(__file__).resolve().parents[1]
if str(LAB_ROOT) not in sys.path:
    sys.path.insert(0, str(LAB_ROOT))

from lab_agents.task_state import TASKS_REL, read_task_registry, task_state_report


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Validate the lab task-state registry and scheduler view.")
    parser.add_argument("--root", type=Path, default=LAB_ROOT, help="Lab root to validate.")
    parser.add_argument("--json", action="store_true", help="Print structured JSON.")
    return parser.parse_args()


def main() -> int:
    args = parse_args()
    root = args.root.expanduser().resolve()
    path = root / TASKS_REL
    try:
        registry = read_task_registry(root)
    except (OSError, json.JSONDecodeError) as exc:
        report = {
            "schema_version": 1,
            "status": "fail",
            "summary": {
                "task_count": 0,
                "pending_count": 0,
                "running_count": 0,
                "blocked_count": 0,
                "review_count": 0,
                "verified_count": 0,
                "done_count": 0,
                "cancelled_count": 0,
                "runnable_count": 0,
                "stale_running_count": 0,
            },
            "next_task": None,
            "issues": [{"code": "TASK_REGISTRY_UNREADABLE", "message": f"{path}: {exc}"}],
        }
    else:
        report = task_state_report(registry)

    if args.json:
        print(json.dumps(report, indent=2, sort_keys=True))
    else:
        print(f"Task state: {report['status']}")
        summary = report["summary"]
        print(
            "Tasks: {task_count}, pending: {pending_count}, running: {running_count}, "
            "blocked: {blocked_count}, review: {review_count}, verified: {verified_count}, "
            "done: {done_count}, runnable: {runnable_count}, stale running: {stale_running_count}".format(
                **summary
            )
        )
        next_task = report.get("next_task")
        if next_task:
            print(f"Next: {next_task['id']} ({next_task['lane']}, priority {next_task['priority']})")
        if report["issues"]:
            for issue in report["issues"]:
                print(f"{issue['code']}: {issue.get('message') or issue.get('task_id')}", file=sys.stderr)

    return 1 if report["status"] == "fail" else 0


if __name__ == "__main__":
    raise SystemExit(main())
