#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LAB_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
DOC="$LAB_ROOT/docs/workflow-modes.md"
SCRIPT="$LAB_ROOT/scripts/workflow-mode"
LAYERS="$LAB_ROOT/registry/CAPABILITY_LAYERS.md"

fail() {
  printf 'FAIL: %s\n' "$*" >&2
  exit 1
}

test -f "$DOC" || fail "missing workflow modes doc"
test -x "$SCRIPT" || fail "workflow-mode script missing or not executable"

modes=(
  daily-app
  cli-diagnosis
  omx-long-horizon
  multi-agent-review
  overnight-checkpoint
)

for mode in "${modes[@]}"; do
  rg -q "\`$mode\`" "$DOC" || fail "mode missing from docs: $mode"
  "$SCRIPT" "$mode" | rg -q "^mode: $mode$" || fail "workflow-mode output missing mode header: $mode"
  "$SCRIPT" "$mode" | rg -q '^entry: ' || fail "workflow-mode output missing entry: $mode"
  "$SCRIPT" "$mode" | rg -q '^verification: ' || fail "workflow-mode output missing verification: $mode"
  "$SCRIPT" "$mode" | rg -q '^stop: ' || fail "workflow-mode output missing stop condition: $mode"
done

listed="$("$SCRIPT" list | sort | tr '\n' ' ')"
expected="$(printf '%s\n' "${modes[@]}" | sort | tr '\n' ' ')"
test "$listed" = "$expected" || fail "workflow-mode list does not match expected modes"

rg -q '^## Layer 2: Workflow Modes$' "$LAYERS" || fail "Layer 2 registry section missing"

printf 'OK: workflow modes are valid\n'
