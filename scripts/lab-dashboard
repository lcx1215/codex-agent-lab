#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
import subprocess
from datetime import datetime, timezone
from pathlib import Path


LAB_ROOT = Path(__file__).resolve().parents[1]
DASHBOARD_ROOT = LAB_ROOT / "outputs" / "shared" / "dashboard"
DASHBOARD_JSON = DASHBOARD_ROOT / "lab-dashboard.json"
DASHBOARD_MD = DASHBOARD_ROOT / "lab-dashboard.md"
BENCH_HISTORY = LAB_ROOT / "outputs" / "shared" / "benchmarks" / "ide-loop" / "history.jsonl"


def read_json(path: Path) -> dict[str, object] | None:
    if not path.exists():
        return None
    return json.loads(path.read_text(encoding="utf-8"))


def latest_json(pattern: str) -> tuple[Path, dict[str, object]] | None:
    candidates = sorted(LAB_ROOT.glob(pattern), key=lambda path: path.stat().st_mtime)
    if not candidates:
        return None
    path = candidates[-1]
    return path, json.loads(path.read_text(encoding="utf-8"))


def load_latest_benchmark() -> dict[str, object] | None:
    if not BENCH_HISTORY.exists():
        return None
    items = [json.loads(line) for line in BENCH_HISTORY.read_text(encoding="utf-8").splitlines() if line.strip()]
    return items[-1] if items else None


def git_summary() -> dict[str, object]:
    completed = subprocess.run(
        ["git", "status", "--short", "--branch"],
        cwd=str(LAB_ROOT),
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        check=False,
    )
    lines = completed.stdout.splitlines()
    entries = [line for line in lines[1:] if line.strip()]
    return {
        "exit_code": completed.returncode,
        "branch": lines[0] if lines else "",
        "dirty_count": len(entries),
        "untracked_count": sum(1 for line in entries if line.startswith("??")),
        "modified_count": sum(1 for line in entries if line[:2].strip() == "M" or " M" in line[:2]),
    }


def build_dashboard() -> dict[str, object]:
    waterflow_report = read_json(LAB_ROOT / "outputs" / "shared" / "waterflow" / "waterflow-report.json")
    waterflow_diff = read_json(LAB_ROOT / "outputs" / "shared" / "waterflow" / "waterflow-path-diff.json")
    changed_plan = read_json(LAB_ROOT / "outputs" / "shared" / "waterflow" / "waterflow-validation-plan-changed.json")
    validation_results = read_json(LAB_ROOT / "outputs" / "shared" / "waterflow" / "waterflow-validation-results.json")
    compatibility = read_json(LAB_ROOT / "outputs" / "shared" / "compatibility" / "runtime-compatibility.json")
    workspace_safety = read_json(LAB_ROOT / "outputs" / "shared" / "workspace-safety" / "workspace-safety.json")
    async_latest = latest_json("outputs/shared/async-execution/*/async-execution-results.json")
    benchmark = load_latest_benchmark()
    git = git_summary()

    findings = (waterflow_report or {}).get("summary", {}).get("finding_count")
    failed_checks = (validation_results or {}).get("summary", {}).get("failed_count")
    async_failed = None
    async_summary = None
    async_path = None
    if async_latest:
        async_path, async_data = async_latest
        async_summary = async_data.get("summary", {})
        async_failed = async_summary.get("failed_count")

    issues: list[str] = []
    if findings not in (0, None):
        issues.append(f"waterflow findings={findings}")
    if failed_checks not in (0, None):
        issues.append(f"waterflow verification failed={failed_checks}")
    if async_failed not in (0, None):
        issues.append(f"async failed={async_failed}")
    if benchmark and benchmark.get("status") != "pass":
        issues.append(f"latest benchmark status={benchmark.get('status')}")
    if compatibility and compatibility.get("status") == "fail":
        failed_count = (compatibility.get("summary") or {}).get("failed_count")
        issues.append(f"runtime compatibility failed={failed_count}")
    if workspace_safety and workspace_safety.get("status") == "fail":
        failed_count = (workspace_safety.get("summary") or {}).get("failed_count")
        issues.append(f"workspace safety failed={failed_count}")

    health = "ok" if not issues else "warn"
    return {
        "schema_version": 1,
        "generated_at": datetime.now(timezone.utc).isoformat(),
        "health": health,
        "issues": issues,
        "git": git,
        "benchmark": benchmark,
        "waterflow": {
            "report": None if waterflow_report is None else waterflow_report.get("summary", {}),
            "diff": None if waterflow_diff is None else waterflow_diff.get("summary", {}),
            "changed_plan": None if changed_plan is None else changed_plan.get("summary", {}),
            "validation": None if validation_results is None else validation_results.get("summary", {}),
        },
        "compatibility": None
        if compatibility is None
        else {
            "status": compatibility.get("status"),
            "summary": compatibility.get("summary"),
        },
        "workspace_safety": None
        if workspace_safety is None
        else {
            "status": workspace_safety.get("status"),
            "summary": workspace_safety.get("summary"),
        },
        "async": {
            "path": None if async_path is None else str(async_path.relative_to(LAB_ROOT)),
            "summary": async_summary,
        },
    }


def fmt_seconds(value: object) -> str:
    if value is None:
        return "-"
    try:
        return f"{float(value):.3f}s"
    except (TypeError, ValueError):
        return str(value)


def render_markdown(data: dict[str, object]) -> str:
    benchmark = data.get("benchmark") or {}
    waterflow = data.get("waterflow") or {}
    async_data = data.get("async") or {}
    compatibility = data.get("compatibility") or {}
    workspace_safety = data.get("workspace_safety") or {}
    git = data.get("git") or {}
    issues = data.get("issues") or []
    lines = [
        "# Lab Dashboard",
        "",
        f"- Generated: `{data.get('generated_at')}`",
        f"- Health: `{data.get('health')}`",
        f"- Issues: `{', '.join(issues) if issues else 'none'}`",
        "",
        "## Benchmark",
        "",
    ]
    if benchmark:
        lines.extend(
            [
                f"- Latest run: `{benchmark.get('run_id')}`",
                f"- Status: `{benchmark.get('status')}`",
                f"- Total: `{fmt_seconds(benchmark.get('total_seconds'))}`",
                f"- Local: `{fmt_seconds(benchmark.get('local_seconds'))}`",
                f"- Gates: `{fmt_seconds(benchmark.get('gate_seconds'))}`",
                f"- Waterflow: `{fmt_seconds(benchmark.get('waterflow_seconds'))}`",
                f"- OMX: `{fmt_seconds(benchmark.get('omx_seconds'))}`",
                f"- Tokens: `{benchmark.get('omx_tokens') or '-'}`",
                f"- History: `outputs/shared/benchmarks/ide-loop/history.md`",
            ]
        )
    else:
        lines.append("- No benchmark history yet.")
    lines.extend(["", "## Waterflow", ""])
    wf_report = waterflow.get("report") or {}
    wf_diff = waterflow.get("diff") or {}
    wf_plan = waterflow.get("changed_plan") or {}
    wf_validation = waterflow.get("validation") or {}
    lines.extend(
        [
            f"- Paths: `{wf_report.get('path_count', '-')}`",
            f"- Findings: `{wf_report.get('finding_count', '-')}`",
            f"- Diff: added `{wf_diff.get('added_count', '-')}`, changed `{wf_diff.get('changed_count', '-')}`, removed `{wf_diff.get('removed_count', '-')}`",
            f"- Changed-only checks: `{wf_plan.get('check_count', '-')}`",
            f"- Verification: passed `{wf_validation.get('passed_count', '-')}`, failed `{wf_validation.get('failed_count', '-')}`",
            "",
            "## Compatibility",
            "",
        ]
    )
    compatibility_summary = compatibility.get("summary") or {}
    lines.extend(
        [
            f"- Status: `{compatibility.get('status', '-')}`",
            f"- Checks: `{compatibility_summary.get('check_count', '-')}`",
            f"- Passed: `{compatibility_summary.get('passed_count', '-')}`",
            f"- Warnings: `{compatibility_summary.get('warning_count', '-')}`",
            f"- Failed: `{compatibility_summary.get('failed_count', '-')}`",
            f"- Report: `outputs/shared/compatibility/runtime-compatibility.md`",
            "",
            "## Workspace Safety",
            "",
        ]
    )
    workspace_summary = workspace_safety.get("summary") or {}
    lines.extend(
        [
            f"- Status: `{workspace_safety.get('status', '-')}`",
            f"- Workspaces: `{workspace_summary.get('workspace_count', '-')}`",
            f"- Passed workspaces: `{workspace_summary.get('passed_count', '-')}`",
            f"- Warnings: `{workspace_summary.get('warning_count', '-')}`",
            f"- Failed: `{workspace_summary.get('failed_count', '-')}`",
            f"- Report: `outputs/shared/workspace-safety/workspace-safety.md`",
            "",
            "## Async",
            "",
        ]
    )
    async_summary = async_data.get("summary") or {}
    lines.extend(
        [
            f"- Latest: `{async_data.get('path') or '-'}`",
            f"- Checks: `{async_summary.get('check_count', '-')}`",
            f"- Passed: `{async_summary.get('passed_count', '-')}`",
            f"- Failed: `{async_summary.get('failed_count', '-')}`",
            f"- Timed out: `{async_summary.get('timed_out_count', '-')}`",
            "",
            "## Git",
            "",
            f"- Branch: `{git.get('branch', '-')}`",
            f"- Dirty entries: `{git.get('dirty_count', '-')}`",
            f"- Modified: `{git.get('modified_count', '-')}`",
            f"- Untracked: `{git.get('untracked_count', '-')}`",
            "",
            "## Next Actions",
            "",
        ]
    )
    if issues:
        lines.extend(f"- Investigate {issue}." for issue in issues)
    elif git.get("dirty_count"):
        lines.append("- Review and stage the current lab changes when ready.")
    else:
        lines.append("- No immediate health action.")
    return "\n".join(lines) + "\n"


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Render the Codex Agent Lab one-screen dashboard.")
    parser.add_argument("--json", action="store_true", help="Print JSON instead of Markdown.")
    return parser.parse_args()


def main() -> int:
    args = parse_args()
    data = build_dashboard()
    markdown = render_markdown(data)
    DASHBOARD_ROOT.mkdir(parents=True, exist_ok=True)
    DASHBOARD_JSON.write_text(json.dumps(data, indent=2, sort_keys=True) + "\n", encoding="utf-8")
    DASHBOARD_MD.write_text(markdown, encoding="utf-8")
    if args.json:
        print(json.dumps(data, indent=2, sort_keys=True))
    else:
        print(markdown, end="")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
