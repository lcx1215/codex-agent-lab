#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LAB_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
name="${1:-task}"
stamp="$(date +%Y%m%d_%H%M%S)"
safe_name="$(printf '%s' "$name" | tr -cs 'A-Za-z0-9._-' '-' | sed 's/^-//; s/-$//')"

fail() {
  printf 'FAIL: %s\n' "$*" >&2
  exit 1
}

workspace_root="${WORKSPACE_ROOT:-$LAB_ROOT/workspaces}"
workspace_root="$(python3 -c 'import os, sys; print(os.path.realpath(sys.argv[1]))' "$workspace_root")"
case "$workspace_root/" in
  "$LAB_ROOT/"*) ;;
  *) fail "WORKSPACE_ROOT must stay inside the lab root" ;;
esac
mkdir -p "$workspace_root"

workspace="$workspace_root/${stamp}-${safe_name:-task}"

mkdir -p "$workspace/agents"
cat > "$workspace/brief.md" <<EOF
# Task Brief

Created: $(date '+%Y-%m-%d %H:%M:%S %z')

## Objective

TBD

## Scenario

- Scenario type: TBD
- Inside boundary: TBD
- Outside boundary: TBD
- Codex/Claude amplification: TBD
- Rule inheritance: root lab rules + this workspace + package-local rules.

## Constraints

- Keep work inside this workspace unless explicitly assigned otherwise.
- Do not read or write secrets.
- Record verification evidence before completion.

## Acceptance Checks

- TBD
EOF

cat > "$workspace/AGENTS.md" <<EOF
# Workspace Rules

This file is the local operating surface for this task workspace.
Use the lab template at ../../docs/project-rule-template.md when this workspace becomes a longer project.

## Scope

- Workspace root: this directory.
- Keep edits inside this workspace unless the parent lab rules or user task name another path.
- Do not read, print, copy, or migrate secrets, auth files, session files, cookies, OTPs, or API keys.

## Rule Inheritance

- Effective rules are the machine/global rules, the root lab rules, this workspace file, and any narrower package-local rules.
- Parent lab contracts still apply: ../../AGENTS.md, ../../CLAUDE.md, ../../docs/environment-layering.md, ../../docs/rule-inheritance.md, and ../../docs/codex-claude-collaboration-protocol.md.
- Local rules can only add detail or narrow scope. They must not weaken parent rules for secrets, auth, provider config, plugin state, lane isolation, sandbox boundaries, collaboration, or promotion.
- If work starts inside agents/<package>/, read this file and the package-local AGENTS.md, CLAUDE.md, README, or manifest before editing.

## Scenario Boundary

- Scenario type: TBD
- This workspace is a scenario surface inside the broader lab; it must not redefine the root lab identity.
- Keep scenario-specific assumptions, fixtures, docs, and experiments local until they prove reusable across scenarios.
- Promote a pattern to the root lab only after it has cross-scenario value, a boundary, and a verification check.

## Codex Claude Amplification

- Use this workspace to focus Codex and Claude with durable context, runnable checks, and concise handoffs.
- Scripts, harnesses, skills, and dashboards should amplify model-agent reasoning and execution, not replace them.
- Keep final integration and verification ownership explicit.

## Routing

- Default workflow mode: TBD
- Use Codex App for short review and GUI work.
- Use codex-api for simple terminal diagnostics.
- Use omx-api for durable, multi-step, risky, or multi-agent work.

## Progress And Validation

- Keep current state in progress.md.
- Record completion evidence in brief.md, progress.md, or a dedicated validation file.
- Do not claim completion without fresh verification or an explicit validation gap.
EOF

cat > "$workspace/CLAUDE.md" <<'EOF'
# Claude Workspace Entry

Claude inherits the same local workspace rules as Codex here.

Read in this order:

1. Root lab `CLAUDE.md`.
2. Root lab `docs/environment-layering.md`.
3. Root lab `docs/rule-inheritance.md`.
4. Root lab `docs/codex-claude-collaboration-protocol.md`.
5. This workspace `AGENTS.md`.
6. The nearest package-local `AGENTS.md`, `CLAUDE.md`, README, or manifest when working inside `agents/<package>/`.

This file is a pointer, not a weaker override. Local rules can only add detail
or narrow scope; parent safety, lane, sandbox, collaboration, and promotion
rules still apply.
EOF

cat > "$workspace/agents/README.md" <<'EOF'
# Agent Packages

Each folder under this directory is a small agent package inside the parent
workspace.

Before editing a package, read the parent workspace `AGENTS.md`, the root lab
`docs/rule-inheritance.md`, and the package-local operating surface (`AGENTS.md`,
`CLAUDE.md`, README, manifest, skills, tools, fixtures, and tests).

Package-local rules can only add detail or narrow scope. They must not weaken
the parent workspace or root lab rules.
EOF

cat > "$workspace/progress.md" <<EOF
# Progress

- Created workspace: $(basename "$workspace")
EOF

cat > "$workspace/.gitignore" <<'EOF'
.DS_Store
.tmp/
.env
.env.*
*.pem
*.key
*.p12
*.pfx
*.token
*.secret
*_token
*_secret
.omx/
.omc/*
!.omc/skills/
!.omc/skills/**
.codex-home/auth.json
.codex-home/log/
.codex-home/sessions/
__pycache__/
*.pyc
*.log
*.tmp
node_modules/
EOF

printf '%s\n' "$workspace"
