#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LAB_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
name="${1:-task}"
stamp="$(date +%Y%m%d_%H%M%S)"
safe_name="$(printf '%s' "$name" | tr -cs 'A-Za-z0-9._-' '-' | sed 's/^-//; s/-$//')"
workspace="$LAB_ROOT/workspaces/${stamp}-${safe_name:-task}"

mkdir -p "$workspace"
cat > "$workspace/brief.md" <<EOF
# Task Brief

Created: $(date '+%Y-%m-%d %H:%M:%S %z')

## Objective

TBD

## Constraints

- Keep work inside this workspace unless explicitly assigned otherwise.
- Do not read or write secrets.
- Record verification evidence before completion.

## Acceptance Checks

- TBD
EOF

cat > "$workspace/progress.md" <<EOF
# Progress

- Created workspace: $workspace
EOF

printf '%s\n' "$workspace"
