#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path


LAB_ROOT = Path(__file__).resolve().parents[1]
if str(LAB_ROOT) not in sys.path:
    sys.path.insert(0, str(LAB_ROOT))

from lab_agents.worktree_merge_queue import (
    MergeQueueError,
    create_stream_worktree,
    enqueue_stream,
    init_state,
    merge_next,
    merge_queue_report,
    read_state,
)


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Create git worktrees and merge them back through an ordered queue.")
    parser.add_argument("--root", type=Path, default=LAB_ROOT, help="Repository root.")
    parser.add_argument("--json", action="store_true", help="Print JSON output.")
    sub = parser.add_subparsers(dest="command", required=True)

    init = sub.add_parser("init", help="Initialize an empty merge-queue state file.")
    init.add_argument("--worktree-root", default=".worktrees/merge-queue")

    create = sub.add_parser("create", help="Create a stream worktree.")
    create.add_argument("stream_id")
    create.add_argument("--branch")

    enqueue = sub.add_parser("enqueue", help="Append a stream to the merge queue.")
    enqueue.add_argument("stream_id")

    sub.add_parser("merge-next", help="Precheck and merge the next queued stream.")
    sub.add_parser("status", help="Validate and summarize merge-queue state.")
    sub.add_parser("state", help="Print raw merge-queue state.")
    return parser.parse_args()


def emit(payload, as_json: bool) -> None:
    if as_json:
        print(json.dumps(payload, indent=2, sort_keys=True))
    else:
        if isinstance(payload, dict) and "status" in payload and "summary" in payload:
            print(f"Merge queue: {payload['status']} {payload['summary']}")
        else:
            print(json.dumps(payload, indent=2, sort_keys=True))


def main() -> int:
    args = parse_args()
    root = args.root.expanduser().resolve()
    try:
        if args.command == "init":
            payload = init_state(root, args.worktree_root)
        elif args.command == "create":
            payload = create_stream_worktree(root, args.stream_id, branch=args.branch)
        elif args.command == "enqueue":
            payload = enqueue_stream(root, args.stream_id)
        elif args.command == "merge-next":
            payload = merge_next(root) or {"status": "empty"}
        elif args.command == "status":
            payload = merge_queue_report(root)
        elif args.command == "state":
            payload = read_state(root)
        else:  # pragma: no cover
            raise AssertionError(args.command)
    except MergeQueueError as exc:
        print(f"FAIL: {exc}", file=sys.stderr)
        return 1
    emit(payload, args.json)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
